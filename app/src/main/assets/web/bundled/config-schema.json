{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Y1 Web Bundle Config",
  "type": "object",
  "properties": {
    "apiBase": {
      "type": "string",
      "default": "/api"
    },
    "updateChannel": {
      "type": "string",
      "default": "stable"
    },
    "updateManifestUrl": {
      "type": "string"
    },
    "featureFlags": {
      "type": "object",
      "properties": {
        "enableAdvancedLibraryOps": { "type": "boolean", "default": false },
        "enablePlaylistBulkActions": { "type": "boolean", "default": true }
      }
    }
  }
}
